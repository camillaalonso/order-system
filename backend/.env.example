DATABASE_URL="postgresql://orders:orders@localhost:5432/orders?schema=public"
QUOTATION_SERVICE_URL="http://localhost:3001"
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Worker
WORKER_POLL_INTERVAL_MS=500

# Quotation client (HTTP + retry + circuit breaker)
QUOTATION_TIMEOUT_MS=1500
QUOTATION_RETRY_ATTEMPTS=3
QUOTATION_RETRY_BASE_MS=100
QUOTATION_BREAKER_THRESHOLD=5
QUOTATION_BREAKER_OPEN_MS=10000
