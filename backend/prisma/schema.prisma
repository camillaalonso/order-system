// Schema do Prisma — define os modelos (tabelas) e o gerador do cliente TS.
// Documentação: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  PENDING
  EXECUTED
  FAILED
  CANCELED
}

model Asset {
  symbol         String   @id
  name           String
  referencePrice Decimal  @db.Decimal(18, 4)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  positions Position[]
  orders    Order[]

  @@map("assets")
}

model User {
  id           String   @id @default(uuid())
  name         String
  cashBalance  Decimal  @db.Decimal(18, 2) @default(0)
  reservedCash Decimal  @db.Decimal(18, 2) @default(0)
  createdAt    DateTime @default(now())

  positions Position[]
  orders    Order[]

  @@map("users")
}

model Position {
  id               String   @id @default(uuid())
  userId           String
  symbol           String
  quantity         Decimal  @db.Decimal(18, 8)
  reservedQuantity Decimal  @db.Decimal(18, 8) @default(0)
  avgPrice         Decimal  @db.Decimal(18, 4)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [symbol], references: [symbol])

  @@unique([userId, symbol])
  @@map("positions")
}

model Order {
  id            String      @id @default(uuid())
  userId        String
  symbol        String
  side          OrderSide
  quantity      Decimal     @db.Decimal(18, 8)
  price         Decimal     @db.Decimal(18, 4)
  totalAmount   Decimal     @db.Decimal(18, 2)
  status        OrderStatus @default(PENDING)
  failureReason String?
  attempts      Int         @default(0)
  createdAt     DateTime    @default(now())
  executedAt    DateTime?

  user  User  @relation(fields: [userId], references: [id])
  asset Asset @relation(fields: [symbol], references: [symbol])

  @@index([userId, createdAt])
  @@map("orders")
}
